{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/adisingh-cs/marlin/schemas/v1/web-api.schema.json",
  "title": "MarlinWebApiPrompt",
  "description": "Domain schema for web API prompts in Marlin",
  "type": "object",
  "required": ["method", "endpoint"],
  "properties": {
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
      "description": "HTTP method for the API endpoint"
    },
    "endpoint": {
      "type": "string",
      "description": "API endpoint path or URL"
    },
    "auth": {
      "type": ["string", "null"],
      "description": "Authentication mechanism (e.g., jwt, oauth2, api-key)"
    },
    "payload": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Request payload fields or parameters"
    },
    "headers": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Required HTTP headers"
    },
    "response-format": {
      "type": "string",
      "default": "json",
      "description": "Expected response format"
    },
    "version": {
      "type": ["string", "null"],
      "description": "API version identifier"
    },
    "middleware": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Middleware layers to apply"
    }
  },
  "additionalProperties": false
}
